# Flask API (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000

# Firebase Authentication (Web app config)
VITE_FIREBASE_API_KEY=see-whatsapp-for-actual-value
VITE_FIREBASE_AUTH_DOMAIN=see-whatsapp-for-actual-value
VITE_FIREBASE_PROJECT_ID=see-whatsapp-for-actual-value
VITE_FIREBASE_STORAGE_BUCKET=see-whatsapp-for-actual-value
VITE_FIREBASE_MESSAGING_SENDER_ID=see-whatsapp-for-actual-value
VITE_FIREBASE_APP_ID=see-whatsapp-for-actual-value

# Practice data (subway + bus sample routes) — no backend required. Set to true for UI demos.
# VITE_USE_MOCK_DATA=true
